modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
MONGO_URL = "mongodb://localhost:27017"
DB_NAME = "reversepicks"
PORT = "8000"
REACT_APP_BACKEND_URL = ""
EXPO_PUBLIC_API_URL = "http://localhost:8000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && npx expo start --web --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p /tmp/mongodb/data && (mongod --dbpath /tmp/mongodb/data --logpath /tmp/mongodb/mongod.log --fork --quiet 2>/dev/null || true) && sleep 5 && cd backend && python -m uvicorn server:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000
